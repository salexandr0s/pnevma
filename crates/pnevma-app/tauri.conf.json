{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pnevma",
  "version": "0.1.0",
  "identifier": "com.pnevma.app",
  "build": {
    "beforeDevCommand": "cd ../../frontend && npm run dev",
    "beforeBuildCommand": "cd ../../frontend && npm run build",
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pnevma",
        "width": 1400,
        "height": 900,
        "resizable": true
      }
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://updates.example.com/pnevma/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "REPLACE_WITH_PNEVMA_UPDATER_PUBKEY"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
